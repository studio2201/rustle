<?xml version="1.0"?>
<Container version="2">
  <Name>rustle</Name>
  <Repository>ghcr.io/studio2201/rustle:latest</Repository>
  <Registry>https://ghcr.io/studio2201/rustle</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/rustle/issues</Support>
  <Project>https://github.com/studio2201/rustle</Project>
  <Overview>High-performance self-hosted word puzzle gameplay engine and web app built in Rust.</Overview>
  <Category>Game:Puzzle Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4502]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/main/templates/rustle.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/main/icons/rustle.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>High-performance self-hosted word puzzle gameplay engine and web app built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4502</HostPort>
        <ContainerPort>4502</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/rustle</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4502</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4502" Default="4502" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4502</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/rustle" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/rustle</Config>
</Container>
